# A Labs — environment variables
# Copy to .env.local for local development (git-ignored). In production, set
# these on the Cloudflare Worker (NEXT_PUBLIC_* must be set as BUILD variables;
# the rest as Secrets).

# Public contact email — shown in the footer, contact page, and mailto links.
# Exposed to the browser (NEXT_PUBLIC_*), so do not put secrets here.
NEXT_PUBLIC_CONTACT_EMAIL=hello@alabs.example.com

# Contact-form email delivery (server-side; set as Cloudflare Secrets).
# Without RESEND_API_KEY the form shows a "email us directly" fallback.
# RESEND_API_KEY=re_xxxxxxxx
# CONTACT_TO_EMAIL=you@example.com          # defaults to NEXT_PUBLIC_CONTACT_EMAIL
# CONTACT_FROM_EMAIL=A Labs <onboarding@resend.dev>
