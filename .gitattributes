# Normalize line endings to LF in the repository for all text files.
# This prevents CRLF/LF churn in diffs across mixed-OS contributors (the dev
# environment is Windows; CI/most editors expect LF). Git checks out with the
# platform's native endings but stores LF.
* text=auto eol=lf

# Explicit text types
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.svg   text eol=lf

# Binary assets — never normalize or diff as text
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.woff  binary
*.woff2 binary
